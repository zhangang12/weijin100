# 复制为 .env 后按需修改

# ── 服务 ──
PORT=3100
NODE_ENV=development

# ── 数据库 / 缓存（本地 docker-compose.dev.yml）──
DATABASE_URL=postgresql://weijin:weijin_dev@localhost:5432/weijin100?schema=public
REDIS_URL=redis://localhost:6379

# ── 行情数据源（脉动 PulseData）──
# 默认：免费测试端口（无需 IP 授权，但仅奇偶小时限时；融通金/伦敦金属偶数小时）
QUOTE_HTTP=http://39.107.99.235:8090/getQuote.php
QUOTE_WS=ws://39.107.99.235:8889
# 正式上线改为（需联系数据商客服 @mdapi888 授权「后端服务器公网 IP」）：
# QUOTE_HTTP=http://39.107.99.235:1008/getQuote.php
# QUOTE_WS=ws://39.107.99.235/ws
POLL_MS=3000
CODE_GOLD=RT_AU
CODE_SILVER=RT_AG
CODE_PLATINUM=RT_PT

# ── 鉴权 ──
JWT_SECRET=change_me_in_prod
JWT_ACCESS_TTL=2h
JWT_REFRESH_TTL=30d

# ── 微信（待业务提供）──
WX_APPID=
WX_SECRET=
WXPAY_MCHID=
WXPAY_APIV3_KEY=
WXPAY_CERT_SERIAL=
# 微信订阅消息模板 ID（小程序后台「订阅消息」申请后填入）
WXMSG_TPLID_ORDER_NOTIFY=       # 订单通知模板
WXMSG_TPLID_PRICE_ALERT=        # 金价提醒模板
WXMSG_TPLID_ARBITRATION=        # 仲裁结果模板

# ── 阿里云 OSS / 短信（待运维提供）──
OSS_REGION=
OSS_BUCKET=
OSS_AK=
OSS_SK=
SMS_SIGN=
SMS_ACCESS_KEY=
SMS_ACCESS_SECRET=
