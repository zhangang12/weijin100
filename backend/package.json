{
  "name": "weijin100-backend",
  "version": "0.1.0",
  "private": true,
  "description": "微金100 后端（NestJS + TypeScript）：脉动行情对接 + REST + WebSocket，实现接口文档 v0.1 契约",
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "seed": "ts-node prisma/seed.ts",
    "dev:pg": "node scripts/pg-embedded.mjs",
    "test": "npm run test:unit",
    "test:unit": "TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register --test test/unit/*.test.ts",
    "test:api": "node test/api-integration.mjs",
    "test:scenarios": "node test/scenarios.mjs",
    "test:integration": "node scripts/integration.mjs"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^10.4.0",
    "@prisma/client": "^5.18.0",
    "prisma": "^5.18.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.12",
    "embedded-postgres": "^18.4.0-beta.17",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.0"
  }
}
