{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "noImplicitAny": true,
    "experimentalDecorators": true,
    "removeComments": false,
    "lib": ["ES2020"],
    "types": ["miniprogram-api-typings"],
    "rootDir": "miniprogram",
    "baseUrl": "miniprogram"
  },
  "include": ["miniprogram/**/*.ts"],
  "exclude": ["node_modules", "miniprogram/miniprogram_npm"]
}
