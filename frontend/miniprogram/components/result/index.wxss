.result { display: flex; flex-direction: column; align-items: center; padding: 60rpx 40rpx; }
.badge { width: 120rpx; height: 120rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 60rpx; font-weight: 800; margin-bottom: 24rpx; }
.badge.ok { background: linear-gradient(180deg, #46c47e, #2B8A5B); box-shadow: 0 16rpx 40rpx rgba(43, 138, 91, .32); }
.badge.err { background: linear-gradient(180deg, #f08a6f, #E0492F); box-shadow: 0 16rpx 40rpx rgba(224, 73, 47, .32); }
.title { font-size: 34rpx; font-weight: 800; color: var(--ink); }
.desc { font-size: 24rpx; color: var(--ink-2); margin-top: 12rpx; text-align: center; line-height: 1.6; }
.ops { width: 100%; margin-top: 36rpx; display: flex; gap: 16rpx; }
