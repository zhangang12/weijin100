.uploader { display: flex; flex-wrap: wrap; gap: 16rpx; }
.img { position: relative; width: 150rpx; height: 150rpx; border-radius: 16rpx; overflow: hidden; }
.img image { width: 100%; height: 100%; }
.img .del { position: absolute; top: 0; right: 0; width: 36rpx; height: 36rpx; background: rgba(0, 0, 0, .5); color: #fff; font-size: 22rpx; display: flex; align-items: center; justify-content: center; border-bottom-left-radius: 12rpx; }
.add { width: 150rpx; height: 150rpx; border-radius: 16rpx; border: 2rpx dashed var(--faint); display: flex; flex-direction: column; align-items: center; justify-content: center; color: var(--muted); background: #fff; }
.add .plus { font-size: 48rpx; line-height: 1; }
.add .cnt { font-size: 20rpx; margin-top: 8rpx; }
