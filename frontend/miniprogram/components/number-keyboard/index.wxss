.kb { background: #fff; border-radius: 24rpx; padding: 16rpx; }
.keys { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14rpx; }
.key { height: 96rpx; border-radius: 16rpx; background: var(--paper); display: flex; align-items: center; justify-content: center; font-size: 40rpx; font-weight: 700; color: var(--ink); }
.key:active { background: var(--cream); }
.key.del { font-size: 34rpx; color: var(--ink-2); }
.confirm { margin-top: 16rpx; height: 88rpx; border-radius: 18rpx; background: linear-gradient(180deg, var(--btn-1), var(--btn-2)); color: #fff; font-size: 30rpx; font-weight: 800; display: flex; align-items: center; justify-content: center; }
