<scroll-view scroll-y class="page">

  <!-- 反馈类型 -->
  <view class="section">
    <text class="section-title">反馈类型</text>
    <view class="type-row">
      <view
        wx:for="{{types}}"
        wx:key="index"
        class="type-chip {{activeType === index ? 'active' : ''}}"
        data-idx="{{index}}"
        bindtap="onTypeSelect"
      >{{item}}</view>
    </view>
  </view>

  <!-- 反馈内容 -->
  <view class="section">
    <text class="section-title">反馈内容</text>
    <view class="textarea-wrap">
      <textarea
        class="textarea"
        placeholder="请描述您的问题或建议..."
        placeholder-class="ta-ph"
        maxlength="500"
        show-confirm-bar="{{false}}"
        value="{{content}}"
        bindinput="onInput"
        auto-height
      ></textarea>
      <text class="word-count">{{content.length}}/500</text>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="cta">
    <view
      class="btn {{(!content.trim() || submitting) ? 'disabled' : ''}}"
      bindtap="onSubmit"
    >{{submitting ? '提交中...' : '提交反馈'}}</view>
  </view>

</scroll-view>
