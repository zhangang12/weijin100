.page { height: 100vh; box-sizing: border-box; padding: 20rpx 24rpx 40rpx; }

.card { background: var(--card); border-radius: var(--radius); padding: 24rpx; box-shadow: var(--shadow); margin-top: 20rpx; }
.card-title { display: block; font-size: 26rpx; font-weight: 700; color: var(--ink-2); margin-bottom: 20rpx; }

/* 免佣横幅 */
.banner {
  background: var(--grad-cream);
  border: 1rpx solid rgba(184, 145, 63, .22);
  border-radius: var(--radius);
  padding: 22rpx 28rpx;
  box-shadow: var(--shadow);
  margin-top: 20rpx;
}
.banner-text { font-size: 28rpx; font-weight: 800; color: var(--gold-3); }

/* 级别卡 */
.level-card {
  background: var(--grad-cream);
  border-radius: var(--radius);
  padding: 32rpx;
  box-shadow: var(--shadow);
  border: 1rpx solid rgba(184, 145, 63, .14);
  margin-top: 20rpx;
}
.lc-head { display: flex; align-items: center; gap: 16rpx; }
.lc-trades { font-size: 28rpx; font-weight: 700; color: var(--ink); }
.lc-bar {
  height: 16rpx; border-radius: 999rpx; background: rgba(184, 145, 63, .16);
  margin-top: 26rpx; overflow: hidden;
}
.lc-bar-fill {
  height: 100%; border-radius: 999rpx;
  background: linear-gradient(90deg, var(--gold-1), var(--gold-3));
  transition: width .3s ease;
}
.lc-next { display: block; font-size: 24rpx; color: var(--ink-2); margin-top: 16rpx; }

/* 费率表 */
.fee-table { border: 1rpx solid var(--line); border-radius: var(--radius-sm); overflow: hidden; }
.fee-row { display: flex; align-items: center; }
.fee-row + .fee-row { border-top: 1rpx solid var(--line); }
.fee-cell {
  flex: 1; text-align: center; font-size: 26rpx; color: var(--ink);
  padding: 22rpx 8rpx;
}
.fee-lv { flex: 0 0 24%; font-weight: 700; color: var(--ink-2); }
.fee-head { background: var(--line-2); }
.fee-head .fee-cell { font-size: 24rpx; font-weight: 700; color: var(--ink-2); padding: 18rpx 8rpx; }
.fee-row.is-current { background: var(--cream); }
.fee-row.is-current .fee-cell { color: var(--gold-3); font-weight: 800; }

.tnum { font-variant-numeric: tabular-nums; }
