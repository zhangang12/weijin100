.page { height: 100vh; box-sizing: border-box; padding: 20rpx 24rpx 40rpx; }

.card { background: var(--card); border-radius: var(--radius); padding: 24rpx; box-shadow: var(--shadow); margin-top: 20rpx; }
.card-title { display: block; font-size: 26rpx; font-weight: 700; color: var(--ink-2); margin-bottom: 20rpx; }
.sub { font-size: 22rpx; font-weight: 400; color: var(--muted); margin-left: 8rpx; }

/* 级别卡 */
.level-card {
  background: var(--grad-cream);
  border-radius: var(--radius);
  padding: 32rpx;
  box-shadow: var(--shadow);
  border: 1rpx solid rgba(184, 145, 63, .14);
  margin-top: 20rpx;
}
.lc-head { display: flex; align-items: center; gap: 16rpx; }
.lc-trades { font-size: 28rpx; font-weight: 700; color: var(--ink); }
.lc-bar {
  height: 16rpx; border-radius: 999rpx; background: rgba(184, 145, 63, .16);
  margin-top: 26rpx; overflow: hidden;
}
.lc-bar-fill {
  height: 100%; border-radius: 999rpx;
  background: linear-gradient(90deg, var(--gold-1), var(--gold-3));
  transition: width .3s ease;
}
.lc-next { display: block; font-size: 24rpx; color: var(--ink-2); margin-top: 16rpx; line-height: 1.6; }

/* 提示条（绿/红） */
.tip {
  display: flex; align-items: flex-start; gap: 12rpx;
  border-radius: var(--radius); padding: 20rpx 24rpx; margin-top: 20rpx;
}
.tip-ic { flex-shrink: 0; font-size: 26rpx; font-weight: 800; line-height: 1.5; }
.tip-text { flex: 1; font-size: 24rpx; line-height: 1.6; }
.tip.ok { background: #E6F4ED; border: 1rpx solid #BFE2D2; }
.tip.ok .tip-ic, .tip.ok .tip-text { color: var(--down); }
.tip.warn { background: #FFF3EC; border: 1rpx solid #F3D2BC; }
.tip.warn .tip-ic, .tip.warn .tip-text { color: var(--up); }
.tip .strong { font-weight: 800; }

/* 费率表 */
.fee-table { border: 1rpx solid var(--line); border-radius: var(--radius-sm); overflow: hidden; }
.fee-row { display: flex; align-items: center; }
.fee-row + .fee-row { border-top: 1rpx solid var(--line); }
.fee-cell {
  flex: 1; text-align: center; font-size: 24rpx; color: var(--ink);
  padding: 20rpx 4rpx;
}
.fee-lv { flex: 0 0 16%; font-weight: 700; color: var(--ink-2); }
.fee-cnt { flex: 0 0 26%; color: var(--ink-2); }
.fee-head { background: var(--line-2); }
.fee-head .fee-cell { font-size: 22rpx; font-weight: 700; color: var(--ink-2); padding: 18rpx 4rpx; }
.fee-row.is-current { background: var(--cream); }
.fee-row.is-current .fee-cell { color: var(--gold-3); font-weight: 800; }

.tnum { font-variant-numeric: tabular-nums; }
