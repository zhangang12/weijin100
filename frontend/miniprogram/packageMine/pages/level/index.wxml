<scroll-view scroll-y class="page" wx:if="{{!loading}}">
  <!-- 级别进度卡 -->
  <view class="level-card">
    <view class="lc-head">
      <lv-badge level="{{currentLevel}}"></lv-badge>
      <text class="lc-trades">已完成 {{completedTrades}} 笔成交</text>
    </view>
    <view class="lc-bar">
      <view class="lc-bar-fill" style="width: {{progressPercent}}%;"></view>
    </view>
    <text class="lc-next">{{levelHint}}</text>
  </view>

  <!-- 运营期免佣提示 -->
  <view class="tip ok" wx:if="{{feeWaived}}">
    <text class="tip-ic">✓</text>
    <text class="tip-text">运营期全场免佣，下表为正式计费费率（按级别递减）。买卖双方完成交易各计 1 笔。</text>
  </view>

  <!-- 佣金费率表（L1-L9 + 累计笔数列） -->
  <view class="card">
    <text class="card-title">佣金费率表 <text class="sub">元 / 克 · 越高级越低</text></text>
    <view class="fee-table">
      <view class="fee-row fee-head">
        <text class="fee-cell fee-lv">级别</text>
        <text class="fee-cell fee-cnt">累计笔数</text>
        <text class="fee-cell">黄金</text>
        <text class="fee-cell">白银</text>
        <text class="fee-cell">铂金</text>
      </view>
      <view
        class="fee-row {{item.current ? 'is-current' : ''}}"
        wx:for="{{feeRows}}"
        wx:key="level"
      >
        <text class="fee-cell fee-lv">{{item.level}}</text>
        <text class="fee-cell fee-cnt tnum">{{item.countRange}}</text>
        <text class="fee-cell tnum">{{item.gold}}</text>
        <text class="fee-cell tnum">{{item.silver}}</text>
        <text class="fee-cell tnum">{{item.platinum}}</text>
      </view>
    </view>
  </view>

  <!-- 违约降级提示 -->
  <view class="tip warn">
    <text class="tip-ic">⚠</text>
    <text class="tip-text"><text class="strong">违约将降级</text>：累计 1 / 2 / 3 次分别降 1 / 2 / 3 级，4 次及以上清零至 L1，降级后按新级别佣金计费。</text>
  </view>
</scroll-view>
