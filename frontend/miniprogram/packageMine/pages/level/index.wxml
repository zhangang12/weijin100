<scroll-view scroll-y class="page" wx:if="{{!loading}}">
  <!-- 运营期免佣横幅 -->
  <view class="banner" wx:if="{{feeWaived}}">
    <text class="banner-text">🎉 运营期全场免佣</text>
  </view>

  <!-- 级别卡 -->
  <view class="level-card">
    <view class="lc-head">
      <lv-badge level="{{currentLevel}}"></lv-badge>
      <text class="lc-trades">当前 {{completedTrades}} 笔成交</text>
    </view>
    <view class="lc-bar">
      <view class="lc-bar-fill" style="width: {{progressPercent}}%;"></view>
    </view>
    <text class="lc-next">再完成 {{tradesToNext}} 笔升级</text>
  </view>

  <!-- 佣金费率表 -->
  <view class="card">
    <text class="card-title">佣金费率表（元/克）</text>
    <view class="fee-table">
      <view class="fee-row fee-head">
        <text class="fee-cell fee-lv">级别</text>
        <text class="fee-cell">黄金</text>
        <text class="fee-cell">白银</text>
        <text class="fee-cell">铂金</text>
      </view>
      <view
        class="fee-row {{item.current ? 'is-current' : ''}}"
        wx:for="{{feeRows}}"
        wx:key="level"
      >
        <text class="fee-cell fee-lv">{{item.level}}</text>
        <text class="fee-cell tnum">{{item.gold}}</text>
        <text class="fee-cell tnum">{{item.silver}}</text>
        <text class="fee-cell tnum">{{item.platinum}}</text>
      </view>
    </view>
  </view>
</scroll-view>
