<scroll-view scroll-y class="page" wx:if="{{!loading}}">
  <view class="hint">实名后方可锁价 / 发布</view>

  <!-- 已实名认证：只读卡 -->
  <block wx:if="{{status === 'verified'}}">
    <view class="card done">
      <view class="badge"><text class="ic">✓</text><text>已实名认证</text></view>
      <view class="frow">
        <text class="fk">真实姓名</text>
        <text class="fv">{{realName}}</text>
      </view>
      <view class="frow">
        <text class="fk">身份证号</text>
        <text class="fv tnum">{{idCardNo}}</text>
      </view>
    </view>
    <view class="locktip">实名信息已锁定，不可修改，用于交易担保与违约追责</view>
  </block>

  <!-- 审核中：提示态（不可重复提交） -->
  <block wx:elif="{{status === 'pending'}}">
    <view class="card pending">
      <view class="pbadge">审核中</view>
      <view class="ptext">实名资料已提交，正在人工审核，请耐心等待</view>
    </view>
  </block>

  <!-- 未认证 / 审核驳回：填写表单 -->
  <block wx:else>
    <view class="card form">
      <view class="field">
        <text class="label">真实姓名</text>
        <input class="input" placeholder="请输入身份证上的姓名" placeholder-class="ph"
               value="{{formName}}" bindinput="onNameInput" maxlength="20" />
      </view>
      <view class="field">
        <text class="label">身份证号</text>
        <input class="input tnum" type="idcard" placeholder="请输入 18 位身份证号" placeholder-class="ph"
               value="{{formIdCard}}" bindinput="onIdInput" maxlength="18" />
      </view>
    </view>

    <view class="card upload">
      <view class="ufield">
        <text class="label">身份证人像面</text>
        <text class="sub">上传带头像的一面</text>
        <uploader value="{{frontFiles}}" max="1" bind:change="onFrontChange"></uploader>
      </view>
      <view class="ufield">
        <text class="label">身份证国徽面</text>
        <text class="sub">上传带国徽的一面</text>
        <uploader value="{{backFiles}}" max="1" bind:change="onBackChange"></uploader>
      </view>
    </view>

    <view class="rejtip" wx:if="{{status === 'rejected'}}">上次认证未通过，请核对信息后重新提交</view>

    <view class="note">仅用于实名核验与交易担保，平台依法保护你的个人信息</view>

    <view class="cta">
      <view class="btn {{submitting ? 'disabled' : ''}}" bindtap="onSubmit">提交认证</view>
    </view>
  </block>
</scroll-view>
