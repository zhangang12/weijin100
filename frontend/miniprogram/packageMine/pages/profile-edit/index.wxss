.page { height: 100vh; box-sizing: border-box; padding: 20rpx 24rpx 40rpx; }

.card { background: var(--card); border-radius: var(--radius); padding: 24rpx; box-shadow: var(--shadow); margin-top: 20rpx; }
.card:first-of-type { margin-top: 0; }

/* 只读身份信息 */
.readonly .frow { display: flex; align-items: center; justify-content: space-between; padding: 22rpx 0; border-top: 1rpx dashed var(--line-2); }
.readonly .frow:first-of-type { border-top: none; padding-top: 6rpx; }
.readonly .fk { font-size: 26rpx; color: var(--ink-2); }
.readonly .fv { font-size: 30rpx; font-weight: 700; color: var(--ink); }

/* 表单 */
.field { padding: 22rpx 0; border-top: 1rpx solid var(--line-2); }
.field:first-child { border-top: none; padding-top: 6rpx; }
.label { display: block; font-size: 26rpx; font-weight: 700; color: var(--ink); }
.input { margin-top: 16rpx; height: 72rpx; font-size: 30rpx; color: var(--ink); border-bottom: 2rpx solid var(--line); }
.ph { color: var(--faint); font-weight: 400; }

/* 手机号行：输入框 + 一键获取按钮 */
.phone-row { display: flex; align-items: flex-end; gap: 16rpx; }
.phone-row .flex1 { flex: 1; }
.getphone {
  flex-shrink: 0;
  margin: 0 0 6rpx 0;
  padding: 0 22rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--gold-3);
  background: var(--cream);
  border: 1rpx solid var(--gold-3);
  border-radius: 999rpx;
}
.getphone::after { border: none; }

.note { font-size: 22rpx; color: var(--muted); text-align: center; padding: 24rpx 20rpx 140rpx; line-height: 1.6; }

.cta { position: fixed; left: 0; right: 0; bottom: 0; padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom)); background: linear-gradient(180deg, rgba(242,239,234,0), var(--paper) 40%); }
.btn { height: 92rpx; border-radius: 20rpx; background: linear-gradient(180deg, var(--btn-1), var(--btn-2)); color: #fff; font-size: 32rpx; font-weight: 800; display: flex; align-items: center; justify-content: center; box-shadow: 0 12rpx 28rpx rgba(184,145,63,.32); }
.btn.disabled { opacity: .6; }

.tnum { font-variant-numeric: tabular-nums; }
