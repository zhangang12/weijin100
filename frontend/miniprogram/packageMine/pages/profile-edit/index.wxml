<scroll-view scroll-y class="page" wx:if="{{!loading}}">
  <!-- 只读身份信息 -->
  <view class="card readonly">
    <view class="frow">
      <text class="fk">微金号</text>
      <text class="fv tnum">{{weijinNo}}</text>
    </view>
    <view class="frow" wx:if="{{realNameMasked}}">
      <text class="fk">实名</text>
      <text class="fv">{{realNameMasked}}</text>
    </view>
    <view class="frow" wx:if="{{level}}">
      <text class="fk">会员级别</text>
      <text class="fv">{{level}}</text>
    </view>
  </view>

  <!-- 可编辑表单 -->
  <view class="card form">
    <!-- 头像：点击更换（相机角标） -->
    <view class="field avatar-field" bindtap="onChooseAvatar">
      <text class="label">头像</text>
      <view class="avatar-edit">
        <view class="avatar-wrap">
          <image wx:if="{{avatar}}" class="avatar-img" src="{{avatar}}" mode="aspectFill" />
          <text wx:else class="avatar-ph">{{avatarChar}}</text>
          <view class="cam"></view>
        </view>
        <text class="avatar-hint">点击更换</text>
      </view>
    </view>

    <view class="field">
      <text class="label">昵称</text>
      <input class="input" placeholder="请输入昵称" placeholder-class="ph"
             value="{{nickname}}" bindinput="onNicknameInput" maxlength="20" />
    </view>

    <view class="field">
      <text class="label">手机号</text>
      <view class="phone-row">
        <input class="input flex1" type="number" placeholder="请输入手机号" placeholder-class="ph"
               value="{{phone}}" bindinput="onPhoneInput" maxlength="11" />
        <button class="getphone" size="mini" open-type="getPhoneNumber" bindgetphonenumber="onGetPhone">微信一键获取</button>
      </view>
    </view>

    <view class="field">
      <text class="label">微信号</text>
      <input class="input" placeholder="请输入微信号" placeholder-class="ph"
             value="{{wechat}}" bindinput="onWechatInput" maxlength="40" />
    </view>
  </view>

  <view class="note">手机 + 微信均必填，用于线下交割时对手方联系</view>

  <view class="cta">
    <view class="btn {{saving ? 'disabled' : ''}}" bindtap="onSave">保存</view>
  </view>
</scroll-view>
