.page { height: 100vh; box-sizing: border-box; padding: 20rpx 24rpx 0; }

.card { background: var(--card); border-radius: var(--radius); padding: 24rpx; box-shadow: var(--shadow); margin-top: 20rpx; }
.card:first-of-type { margin-top: 0; }

/* 关联违约记录摘要卡（只读） */
.card.ref { padding: 22rpx 24rpx; }
.ref .ref-row { display: flex; align-items: center; justify-content: space-between; }
.ref .rk { font-size: 26rpx; color: var(--ink); font-weight: 700; }
.ref .rv { font-size: 26rpx; color: var(--gold-3); font-weight: 800; }
.ref .ref-desc { display: block; font-size: 24rpx; color: var(--ink-2); margin-top: 12rpx; line-height: 1.6; }

/* 黄色提示条 */
.tip { margin-top: 20rpx; background: var(--cream); border: 1rpx solid var(--line); border-radius: var(--radius-sm);
       padding: 20rpx 24rpx; font-size: 24rpx; line-height: 1.7; color: var(--tag-orange); font-weight: 600; }

/* 表单字段 */
.field { padding: 6rpx 0; }
.label { display: block; font-size: 28rpx; font-weight: 700; color: var(--ink); }
.req { color: var(--up); font-weight: 800; }
.sub { display: block; font-size: 22rpx; color: var(--muted); margin: 8rpx 0 18rpx; }
.ph { color: var(--faint); font-weight: 400; }

/* 申诉理由 textarea */
.ta { margin-top: 18rpx; width: 100%; box-sizing: border-box; min-height: 220rpx; font-size: 28rpx; line-height: 1.6; color: var(--ink);
      background: var(--paper); border: 1rpx solid var(--line); border-radius: var(--radius-sm); padding: 20rpx 22rpx; }
.count { display: block; text-align: right; font-size: 22rpx; color: var(--muted); margin-top: 12rpx; }

.bottom-hold { height: 140rpx; }

/* 底部提交按钮 */
.cta { position: fixed; left: 0; right: 0; bottom: 0; padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom)); background: linear-gradient(180deg, rgba(242,239,234,0), var(--paper) 40%); }
.btn { height: 92rpx; border-radius: 20rpx; background: linear-gradient(180deg, var(--btn-1), var(--btn-2)); color: #fff; font-size: 32rpx; font-weight: 800; display: flex; align-items: center; justify-content: center; box-shadow: 0 12rpx 28rpx rgba(184,145,63,.32); }
.btn.disabled { opacity: .6; }

.tnum { font-variant-numeric: tabular-nums; }
