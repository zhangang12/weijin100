.page { height: 100vh; box-sizing: border-box; padding: 20rpx 24rpx 0; }

/* 顶部说明 */
.note {
  font-size: 22rpx; color: var(--muted); line-height: 1.6;
  background: var(--cream); border: 1rpx solid rgba(184, 145, 63, .22);
  border-radius: 14rpx; padding: 16rpx 20rpx; margin-bottom: 20rpx;
}

/* 空 / 加载态 */
.empty { padding: 120rpx 0; text-align: center; color: var(--muted); font-size: 26rpx; }
.empty-ic { font-size: 72rpx; margin-bottom: 16rpx; }
.empty-t { font-size: 26rpx; color: var(--muted); }

/* 地址列表 */
.list { display: flex; flex-direction: column; gap: 20rpx; }
.addr {
  background: var(--card); border-radius: var(--radius);
  padding: 24rpx; box-shadow: var(--shadow);
}
.addr-hd { display: flex; align-items: center; gap: 14rpx; margin-bottom: 16rpx; }
.badge-default {
  font-size: 18rpx; font-weight: 700; color: var(--gold-3);
  background: var(--cream); border: 1rpx solid rgba(184, 145, 63, .35);
  padding: 2rpx 12rpx; border-radius: 8rpx; line-height: 1.7;
}
.addr-line { display: flex; align-items: baseline; gap: 20rpx; }
.contact { font-size: 30rpx; font-weight: 800; color: var(--ink); }
.phone { font-size: 26rpx; color: var(--ink-2); font-variant-numeric: tabular-nums; }
.addr-detail { font-size: 26rpx; color: var(--ink-2); line-height: 1.6; margin-top: 12rpx; }

/* 操作区 */
.addr-ops {
  display: flex; justify-content: flex-end; gap: 16rpx;
  margin-top: 20rpx; padding-top: 18rpx; border-top: 2rpx solid var(--line);
}
.op {
  font-size: 24rpx; font-weight: 700; color: var(--gold-3);
  padding: 8rpx 24rpx; border-radius: 999rpx;
  border: 1rpx solid rgba(184, 145, 63, .35); background: var(--cream);
}
.op-disabled { color: var(--muted); background: var(--paper); border-color: var(--line); }
.op-del { color: var(--up); background: #FFEBE7; border-color: rgba(214, 69, 65, .25); }

.bottom-space { height: 160rpx; }

/* 底部按钮 */
.cta {
  position: fixed; left: 0; right: 0; bottom: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(242, 239, 234, 0), var(--paper) 40%);
}
.btn {
  height: 92rpx; border-radius: 20rpx;
  background: linear-gradient(180deg, var(--btn-1), var(--btn-2)); color: #fff;
  font-size: 32rpx; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 12rpx 28rpx rgba(184, 145, 63, .32);
}
.btn.disabled {
  background: var(--paper); color: var(--muted);
  box-shadow: none; border: 1rpx solid var(--line);
}

/* 表单（弹窗内） */
.form { padding: 8rpx 0 16rpx; }
.field {
  display: flex; align-items: center; gap: 20rpx;
  padding: 22rpx 0; border-bottom: 2rpx solid var(--line);
}
.field-col { flex-direction: column; align-items: stretch; gap: 14rpx; }
.field-k { font-size: 28rpx; font-weight: 700; color: var(--ink-2); min-width: 132rpx; }
.ipt {
  flex: 1; height: 56rpx; font-size: 28rpx; color: var(--ink);
  text-align: right;
}
.field-col .ipt { text-align: left; }
.area { height: auto; min-height: 96rpx; text-align: left; line-height: 1.6; }
.ph { color: var(--faint); }

/* segment */
.seg { flex: 1; display: flex; background: var(--paper); border-radius: 999rpx; padding: 6rpx; }
.seg-i {
  flex: 1; height: 60rpx; line-height: 60rpx; text-align: center;
  font-size: 26rpx; color: var(--ink-2); border-radius: 999rpx; transition: all .18s;
}
.seg-i.on {
  background: linear-gradient(180deg, var(--btn-1), var(--btn-2));
  color: #fff; font-weight: 700; box-shadow: 0 6rpx 16rpx rgba(184, 145, 63, .3);
}

.switch-row { justify-content: space-between; }

/* 保存按钮 */
.save-btn {
  margin-top: 32rpx; height: 92rpx; border-radius: 20rpx;
  background: linear-gradient(180deg, var(--btn-1), var(--btn-2)); color: #fff;
  font-size: 32rpx; font-weight: 800;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 12rpx 28rpx rgba(184, 145, 63, .32);
}
.save-btn.disabled { opacity: .6; }
