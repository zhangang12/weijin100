<scroll-view scroll-y class="page" wx:if="{{!loading && detail}}">

  <!-- 1. 状态卡 -->
  <view class="card status">
    <view class="st-row">
      <tag text="{{statusText}}" type="{{statusTagType}}"></tag>
      <text class="st-side">{{sideText}}</text>
    </view>

    <!-- 锁价待处理：交割倒计时（A2 超时继续展示） -->
    <block wx:if="{{isLocked}}">
      <view class="st-count">
        <text class="cd-label">{{isOvertime ? '已超过 4 小时履约时限' : '交割倒计时'}}</text>
        <text class="cd-time tnum {{isOvertime ? 'over' : ''}}">{{countdownText}}</text>
      </view>
      <view class="st-tip">
        <text class="st-dot"></text>
        <text class="st-tip-text">请在 <text class="hl">4 小时</text>内完成线下实名交割；超时未交割可由对方发起仲裁，平台判定</text>
      </view>
    </block>

    <!-- 销售中：暂无买家锁价提示 -->
    <view wx:if="{{isSelling}}" class="sell-note">
      暂无买家锁价，可随时修改报价 / 调增克重，或取消剩余库存挂单；已被锁价的子单不可取消。
    </view>

    <!-- 代交接核验中：交割方式已锁定（B8） -->
    <view wx:if="{{isRelayInProgress}}" class="relay-lock">交割方式：平台代交接 · 已锁定，不可改回当面自交</view>
  </view>

  <!-- 2. 商品卡 -->
  <view class="card goods">
    <view class="g-head">
      <text class="g-name">{{detail.productName}}</text>
      <text class="g-weight tnum">{{detail.weight}}g</text>
    </view>

    <!-- 销售中：挂单总量 / 剩余可锁 / 出货方式 -->
    <view wx:if="{{isSelling}}" class="g-sell">
      <view class="gs-row">
        <text class="gs-k">挂单总量</text>
        <text class="gs-v tnum">{{detail.weight}}g</text>
      </view>
      <view class="gs-row" wx:if="{{detail.remainingWeight}}">
        <text class="gs-k">剩余可锁</text>
        <text class="gs-v hl tnum">{{detail.remainingWeight}}g</text>
      </view>
      <view class="gs-row" wx:if="{{shipText}}">
        <text class="gs-k">出货方式</text>
        <text class="gs-v">{{shipText}}</text>
      </view>
    </view>

    <view class="g-prices">
      <view class="g-price">
        <text class="gp-k">{{isSelling ? '现金参考价' : '现金合计'}}</text>
        <text class="gp-cash" wx:if="{{isSelling}}"><text class="tnum">{{detail.priceCash}}</text> 元/克</text>
        <text class="gp-cash" wx:else>¥<text class="tnum">{{totalCashText}}</text></text>
      </view>
      <view class="g-price" wx:if="{{detail.supportsTransfer}}">
        <text class="gp-k">{{isSelling ? '转账参考价' : '转账合计'}}</text>
        <text class="gp-transfer" wx:if="{{isSelling}}"><text class="tnum">{{detail.priceTransfer}}</text> 元/克</text>
        <text class="gp-transfer" wx:else>¥<text class="tnum">{{totalTransferText}}</text></text>
      </view>
    </view>
  </view>

  <!-- 2b. 实时报价小卡（销售中） -->
  <view class="card quote" wx:if="{{isSelling && quoteMarket}}">
    <view class="q-head">
      <text class="q-title">实时报价</text>
      <text class="q-live">实时跳动</text>
    </view>
    <view class="q-body">
      <view class="q-cell">
        <text class="q-k">大盘金价</text>
        <text class="q-v tnum {{quoteTrendClass}}">{{quoteMarket}}</text>
        <text class="q-chg tnum {{quoteTrendClass}}">{{quoteChangeText}}</text>
      </view>
    </view>
  </view>

  <!-- 3. 对手方联系卡（非销售中） -->
  <view class="card contact" wx:if="{{!isSelling}}">
    <view class="c-head">
      <text class="c-role">{{detail.counterparty.role}}</text>
      <text class="c-user">{{detail.counterparty.userMasked}}</text>
      <lv-badge level="{{detail.counterparty.level}}"></lv-badge>
      <text class="c-region" wx:if="{{detail.counterparty.region}}">{{detail.counterparty.region}}</text>
    </view>

    <view class="c-row">
      <view class="c-info">
        <text class="c-k">电话</text>
        <text class="c-v">{{detail.counterparty.phone}}</text>
      </view>
      <view class="c-btn call" bindtap="onCall">拨打</view>
    </view>

    <view class="c-row">
      <view class="c-info">
        <text class="c-k">微信</text>
        <text class="c-v">{{detail.counterparty.wechat}}</text>
      </view>
      <view class="c-btn copy" bindtap="onCopyWechat">复制</view>
    </view>

    <view class="c-row">
      <view class="c-info">
        <text class="c-k">地址</text>
        <text class="c-v addr">{{detail.counterparty.address}}</text>
      </view>
      <view class="c-btn nav" bindtap="onNavigate">导航</view>
    </view>
  </view>

  <!-- 3b. 代交接状态提示条 -->
  <view class="card relay-wait" wx:if="{{isLocked && relayPending && amInitiator}}">
    <text class="rw-title">已申请平台代交接</text>
    <text class="rw-desc">服务费 ¥100 已支付，等待对方同意后进入平台核验流程。</text>
  </view>
  <view class="card relay-consent" wx:if="{{isLocked && canConsent}}">
    <text class="rw-title">对方已申请平台代交接</text>
    <text class="rw-desc">服务费 ¥100 已由对方支付。同意后交割方式将锁定为平台代交接（不可改回当面自交），进入平台看货核验、买家打款即完成并释放双方保证金。</text>
  </view>

  <!-- 4. 订单信息卡 -->
  <view class="card info">
    <view class="i-row">
      <text class="i-k">订单号</text>
      <text class="i-v tnum">{{detail.orderNo}}</text>
    </view>
    <view class="i-row">
      <text class="i-k">下单时间</text>
      <text class="i-v tnum">{{createTimeText}}</text>
    </view>
    <view class="i-row" wx:if="{{isCompleted}}">
      <text class="i-k">完成时间</text>
      <text class="i-v tnum">{{completeTimeText}}</text>
    </view>
    <view class="i-row" wx:if="{{deliveryText}}">
      <text class="i-k">交割方式</text>
      <text class="i-v">{{deliveryText}}</text>
    </view>
  </view>

  <view class="bottom-pad"></view>

  <!-- 底部操作栏（按状态区分） -->
  <!-- 锁价待处理·常规态 -->
  <view class="actionbar" wx:if="{{isLocked && !relayPending && !canConsent}}">
    <view class="ab-row">
      <view class="btn ghost" bindtap="onArbitration">申请仲裁</view>
      <view class="btn ghost" bindtap="openRelay">平台代交接</view>
    </view>
    <view class="btn primary" bindtap="openConfirm">确认交易完成</view>
  </view>
  <!-- 锁价待处理·我是发起方，等待对方同意 -->
  <view class="actionbar" wx:elif="{{isLocked && relayPending && amInitiator}}">
    <view class="ab-row">
      <view class="btn ghost" bindtap="onArbitration">申请仲裁</view>
      <view class="btn ghost" bindtap="goRelay">查看代交接进度</view>
    </view>
  </view>
  <!-- 锁价待处理·我是对手方，可同意代交接 -->
  <view class="actionbar" wx:elif="{{isLocked && canConsent}}">
    <view class="ab-row">
      <view class="btn ghost" bindtap="onArbitration">申请仲裁</view>
    </view>
    <view class="btn primary" bindtap="onConsent">同意代交接</view>
  </view>
  <!-- 代交接核验中 -->
  <view class="actionbar" wx:elif="{{isRelayInProgress}}">
    <view class="btn primary" bindtap="goRelay">查看代交接进度</view>
  </view>
  <!-- 销售中·我的挂单 -->
  <view class="actionbar" wx:elif="{{isSelling}}">
    <view class="ab-row">
      <view class="btn ghost danger" bindtap="onCancelListing">取消订单</view>
      <view class="btn primary" bindtap="onEditListing">修改商品参数</view>
    </view>
  </view>

</scroll-view>

<!-- 确认交易完成 · 核验清单 -->
<sheet show="{{showConfirm}}" title="确认交易完成" bind:close="closeConfirm">
  <view class="cf-list">
    <view class="cf-item"><text class="cf-n">1</text><text>已当面核验实物品质无误（成色、克重、品牌）</text></view>
    <view class="cf-item"><text class="cf-n">2</text><text>货款已结清（现金当面交付 / 转账已到账）</text></view>
    <view class="cf-item"><text class="cf-n">3</text><text>确认交割完成后订单即终结，不可撤销</text></view>
  </view>
  <view class="cf-tip">需买卖双方各自确认；一方确认后，另一方 24 小时无确认将自动完成（B2）</view>
  <view class="cf-btn" bindtap="onConfirmSubmit">确认完成</view>
</sheet>

<!-- 平台代交接 · 申请 -->
<sheet show="{{showRelay}}" title="申请平台代交接" bind:close="closeRelay">
  <view class="rl-fee"><text>服务费</text><text class="rl-amt">¥100 / 单</text></view>
  <view class="rl-steps">
    <view class="rl-step"><text class="rl-i">1</text><text>卖家送货到平台服务点（就近水贝现货核验点）</text></view>
    <view class="rl-step"><text class="rl-i">2</text><text>平台专员看货核验（成色 / 克重 / 品牌，拍照留档）</text></view>
    <view class="rl-step"><text class="rl-i">3</text><text>买家打款 · 交易完成，释放双方保证金</text></view>
    <view class="rl-step"><text class="rl-i">4</text><text>平台发货给买家（仅物流配送）</text></view>
  </view>
  <view class="rl-note">发起方支付 ¥100（可协商分摊），需对方同意后生效；一经转代交接不可改回当面自交</view>
  <view class="cf-btn" bindtap="onRelaySubmit">支付 ¥100 并申请</view>
</sheet>
