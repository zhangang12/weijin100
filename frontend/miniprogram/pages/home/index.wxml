<view class="page">
  <view class="hd">
    <view class="hd-logo">金</view>
    <view class="hd-brand">
      <view class="b1">微金100</view>
      <view class="b2">天天实时行情</view>
    </view>
    <view class="hd-sub" bindtap="onSubscribe">订阅</view>
  </view>

  <!-- 品类折页 Tab（屏1批注5）：切换联动行情卡 + 列表 + 主题色 -->
  <view class="mkt-wrap">
    <view class="mkt-track"></view>
    <view class="mkt-tabs">
      <view
        wx:for="{{metalTabs}}"
        wx:key="key"
        data-metal="{{item.key}}"
        bindtap="onMetal"
        class="mkt-tab {{metal === item.key ? 'on' : ''}} {{item.key === 'silver' ? 'ag' : (item.key === 'platinum' ? 'pt' : '')}}"
      >{{item.label}}</view>
    </view>
  </view>

  <price-card quote="{{quote}}" />

  <view class="chips">
    <view
      wx:for="{{chips}}"
      wx:key="*this"
      data-chip="{{item}}"
      bindtap="onChip"
      class="chip {{activeChip === item ? 'on' : ''}}"
    >{{item}}</view>
  </view>

  <!-- 排序栏 + 结果计数（屏3批注2） -->
  <view class="sortbar">
    <view
      wx:for="{{sortOptions}}"
      wx:key="key"
      data-key="{{item.key}}"
      bindtap="onSort"
      class="sort {{sortKey === item.key ? 'on' : ''}}"
    >
      <text>{{item.label}}</text>
      <text wx:if="{{sortKey === item.key}}" class="arrow">{{sortDir === 'desc' ? '↓' : '↑'}}</text>
    </view>
    <view class="sp"></view>
    <view class="sort-cnt">共 <text class="n">{{total}}</text> 条 · {{activeChip}}</view>
  </view>

  <view class="list-head">
    <text class="lh-name">名称 / 类别</text>
    <text class="lh-stock">库存/起批</text>
    <text class="lh-price">价格(元/克)</text>
    <text class="lh-act">操作</text>
  </view>

  <view class="list">
    <goods-row
      wx:for="{{listings}}"
      wx:key="listingId"
      item="{{item}}"
      bind:lock="onLock"
    />
    <!-- 空态（屏1/3） -->
    <view wx:if="{{!loading && !loadingMore && listings.length === 0}}" class="empty">
      该筛选暂无挂单，换个条件试试
    </view>
  </view>

  <!-- 底部：加载中 / 已经到底啦（屏3批注4） -->
  <view class="foot">
    <block wx:if="{{loading}}">加载中…</block>
    <block wx:elif="{{loadingMore}}">正在加载更多…</block>
    <block wx:elif="{{listings.length > 0 && !hasMore}}">—— 已经到底啦 ——</block>
    <block wx:elif="{{hasMore}}">上拉加载更多</block>
  </view>
</view>

<!-- 订阅金价提醒底部弹窗（屏4） -->
<view wx:if="{{sheetVisible}}" class="dim" bindtap="closeSubscribe">
  <view class="sheet" catchtap="noop">
    <view class="sh">
      <text class="t">订阅金价提醒</text>
      <text class="x" bindtap="closeSubscribe">✕</text>
    </view>

    <!-- 品类：与首页折页解耦，可订阅非当前浏览品类 -->
    <view class="seg">
      <view
        wx:for="{{metalTabs}}"
        wx:key="key"
        data-metal="{{item.key}}"
        bindtap="onSubMetal"
        class="s {{subMetal === item.key ? 'on' : ''}}"
      >{{item.label}}</view>
    </view>

    <view class="sub-lab">提醒条件</view>
    <view class="cond">
      <view class="c {{subCond === 'above' ? 'on' : ''}}" data-cond="above" bindtap="onSubCond">
        <view class="cl">价格涨到</view>
        <view class="cs">高于目标价时提醒</view>
      </view>
      <view class="c {{subCond === 'below' ? 'on' : ''}}" data-cond="below" bindtap="onSubCond">
        <view class="cl">价格跌到</view>
        <view class="cs">低于目标价时提醒</view>
      </view>
    </view>

    <view class="sub-lab">目标价（元/克）· 当前 {{subCurrentText}}</view>
    <view class="price-input">
      <text class="yen">¥</text>
      <input value="{{subTarget}}" bindinput="onSubInput" type="digit" placeholder="输入目标价" />
      <text class="unit">元/克</text>
    </view>
    <view class="quick-px">
      <view class="q {{subQuick === '0.5' ? 'on' : ''}}" data-quick="0.5" bindtap="onSubQuick">+0.5%</view>
      <view class="q {{subQuick === '1' ? 'on' : ''}}" data-quick="1" bindtap="onSubQuick">+1%</view>
      <view class="q {{subQuick === '2' ? 'on' : ''}}" data-quick="2" bindtap="onSubQuick">+2%</view>
      <view class="q {{subQuick === 'manual' ? 'on' : ''}}" data-quick="manual" bindtap="onSubQuick">手动</view>
    </view>

    <view class="sub-lab">提醒方式</view>
    <view class="notif-rows">
      <view class="notif-row">
        <view class="notif-ic push">推</view>
        <view class="notif-tx">
          <view class="n1">应用推送</view>
          <view class="n2">微金100 App 推送通知</view>
        </view>
        <view class="sw {{subPush ? 'on' : ''}}" data-ch="push" bindtap="onSubToggle"></view>
      </view>
      <view class="notif-row">
        <view class="notif-ic sms">信</view>
        <view class="notif-tx">
          <view class="n1">短信提醒</view>
          <view class="n2">复用「我的」已验证手机号</view>
        </view>
        <view class="sw {{subSms ? 'on' : ''}}" data-ch="sms" bindtap="onSubToggle"></view>
      </view>
    </view>

    <view class="warm-tip">金价波动剧烈，到价提醒仅供参考，不构成交易建议。每品类最多可设 8 条提醒。</view>
    <view class="sub-btn" bindtap="submitSubscribe">开启提醒</view>
  </view>
</view>
