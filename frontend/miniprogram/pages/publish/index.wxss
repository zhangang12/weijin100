.page { min-height: 100vh; box-sizing: border-box; padding: 60rpx 40rpx; }

.hero { background: var(--grad-cream); border-radius: var(--radius); padding: 56rpx 40rpx; text-align: center; box-shadow: var(--shadow); }
.hero-ic { width: 110rpx; height: 110rpx; margin: 0 auto 24rpx; border-radius: 30rpx; background: linear-gradient(150deg, #F6E6BD, #B8913F); color: #fff; font-weight: 800; font-size: 50rpx; display: flex; align-items: center; justify-content: center; box-shadow: 0 10rpx 24rpx rgba(184,145,63,.32); }
.hero-t { font-size: 38rpx; font-weight: 800; color: var(--ink); }
.hero-d { font-size: 24rpx; color: var(--ink-2); margin-top: 12rpx; }
.hero-btn { margin: 40rpx auto 0; width: 60%; height: 92rpx; border-radius: 20rpx; background: linear-gradient(180deg, var(--btn-1), var(--btn-2)); color: #fff; font-size: 32rpx; font-weight: 800; display: flex; align-items: center; justify-content: center; box-shadow: 0 12rpx 28rpx rgba(184,145,63,.32); }

.tips { margin-top: 40rpx; display: flex; flex-direction: column; gap: 20rpx; padding: 0 12rpx; }
.tip { display: flex; align-items: center; font-size: 26rpx; color: var(--ink-2); }
.tip .dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: var(--gold-3); margin-right: 16rpx; }

.rules { display: flex; flex-direction: column; gap: 18rpx; margin-bottom: 24rpx; }
.rule { display: flex; gap: 14rpx; font-size: 25rpx; color: var(--ink-2); line-height: 1.6; }
.rule .rn { flex: 0 0 32rpx; width: 32rpx; height: 32rpx; border-radius: 50%; background: #FFF1E5; color: var(--tag-orange); font-size: 20rpx; font-weight: 800; display: flex; align-items: center; justify-content: center; margin-top: 4rpx; }
.rule .rt { flex: 1; }

.agree { display: flex; align-items: center; gap: 12rpx; font-size: 26rpx; color: var(--ink-2); padding: 8rpx 0 24rpx; }
.agree .check { width: 34rpx; height: 34rpx; border-radius: 8rpx; border: 2rpx solid var(--faint); color: #fff; font-size: 24rpx; display: flex; align-items: center; justify-content: center; }
.agree .check.on { background: linear-gradient(135deg, var(--btn-1), var(--btn-2)); border-color: transparent; }

.confirm-btn { height: 92rpx; border-radius: 20rpx; background: linear-gradient(180deg, var(--btn-1), var(--btn-2)); color: #fff; font-size: 32rpx; font-weight: 800; display: flex; align-items: center; justify-content: center; box-shadow: 0 12rpx 28rpx rgba(184,145,63,.32); }
.confirm-btn.disabled { opacity: .5; }
