<view class="page">
  <view class="hero">
    <view class="hero-ic">金</view>
    <view class="hero-t">发布现货挂单</view>
    <view class="hero-d">发布你的水贝实物现货，等待买家锁价成交</view>
    <view class="hero-btn" bindtap="openRules">发布现货</view>
  </view>

  <view class="tips">
    <view class="tip"><text class="dot"></text>支持大盘价 + 溢价 / 一口固定价两种定价</view>
    <view class="tip"><text class="dot"></text>整出全量 / 整出固量 / 散出灵活出货</view>
    <view class="tip"><text class="dot"></text>发布需实名 + 联系方式 + 保证金</view>
  </view>
</view>

<!-- 发布须知：居中弹窗，不可点遮罩关闭，双按钮（屏1） -->
<view class="rules-mask {{showRules ? 'on' : ''}}" catchtouchmove="noop" catchtap="noop">
  <view class="rules-pop {{showRules ? 'in' : ''}}" catchtap="noop">
    <view class="pop-ic">!</view>
    <view class="pop-t">发布须知</view>
    <view class="rules">
      <view class="rule" wx:for="{{rules}}" wx:key="*this">
        <text class="rn">{{index + 1}}</text>
        <text class="rt">{{item}}</text>
      </view>
    </view>
    <view class="agree" bindtap="onToggleAgree">
      <text class="check {{agreed ? 'on' : ''}}">{{agreed ? '✓' : ''}}</text>
      <text>我已阅读并同意以上发布规则</text>
    </view>
    <view class="pop-ops">
      <view class="confirm-btn line" bindtap="closeRules">暂不发布</view>
      <view class="confirm-btn {{agreed ? '' : 'disabled'}}" bindtap="onConfirm">同意并继续</view>
    </view>
  </view>
</view>
