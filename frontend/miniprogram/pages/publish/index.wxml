<scroll-view scroll-y class="page">
  <!-- 标题区 -->
  <view class="hd">
    <view class="hd-title">发布现货</view>
    <view class="hd-sub">仅限水贝实物现货 · 线下实名交割</view>
  </view>

  <!-- 合规须知卡 -->
  <view class="card notice">
    <view class="notice-hd">
      <text class="notice-ic">!</text>
      <text class="notice-tt">发布须知 · 合规要求</text>
    </view>
    <view class="rules">
      <view class="rule" wx:for="{{rules}}" wx:key="index">
        <text class="rule-no">{{index + 1}}</text>
        <text class="rule-tx">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 勾选同意 -->
  <view class="agree" bindtap="onToggleAgree">
    <view class="cbox {{agreed ? 'on' : ''}}">
      <text wx:if="{{agreed}}" class="cbox-tick">✓</text>
    </view>
    <text class="agree-tx">我已阅读并同意《发布须知》</text>
  </view>

  <!-- 资质提示（小字） -->
  <view class="hint">发布需：实名 + 联系方式 + 保证金，点「开始发布」会自动校验。</view>

  <!-- 底部按钮 -->
  <view class="footer">
    <button
      class="btn {{agreed ? '' : 'btn-off'}}"
      disabled="{{!agreed}}"
      bindtap="onStart"
    >开始发布</button>
  </view>
</scroll-view>
