<view class="page">

  <!-- 功能受限 banner（E5：可看行情/管已有订单，不能发布/锁价） -->
  <view class="limit-banner" wx:if="{{isLimited}}">
    <text class="lb-ic">🚫</text>
    <text class="lb-text">账号功能受限：暂不能发布挂单 / 锁价，可查看行情、管理已有订单</text>
  </view>

  <!-- 用户头卡 -->
  <view class="card user">
    <view class="avatar">{{avatarChar || '微'}}</view>
    <view class="u-main">
      <view class="u-top">
        <text class="u-name">{{profile.nickname || '微金用户'}}</text>
        <lv-badge wx:if="{{profile}}" level="{{profile.level}}"></lv-badge>
      </view>
      <view class="u-no" bindtap="onCopyNo">
        <text class="u-no-t">微金号 {{profile.weijinNo || '--'}}</text>
        <text class="u-copy">复制</text>
      </view>
      <view class="u-kyc {{isVerified ? 'on' : ''}}">
        <text wx:if="{{isVerified}}">已实名 {{profile.realNameMasked || ''}}</text>
        <text wx:else>未实名</text>
      </view>
    </view>
  </view>

  <!-- 保证金卡（奶油金渐变） -->
  <view class="card margin">
    <view class="m-label">保证金余额</view>
    <view class="m-balance">
      <text class="m-cny">¥</text>
      <text class="m-num">{{balanceText}}</text>
    </view>

    <view class="m-quota">
      <view class="q-item">
        <text class="q-v">{{margin.quota.gold || 0}}<text class="q-u">g</text></text>
        <text class="q-k">黄金</text>
      </view>
      <view class="q-sep"></view>
      <view class="q-item">
        <text class="q-v">{{margin.quota.silver || 0}}<text class="q-u">g</text></text>
        <text class="q-k">白银</text>
      </view>
      <view class="q-sep"></view>
      <view class="q-item">
        <text class="q-v">{{margin.quota.platinum || 0}}<text class="q-u">g</text></text>
        <text class="q-k">铂金</text>
      </view>
    </view>

    <view class="m-btns">
      <view class="m-btn primary" bindtap="onRecharge">充值保证金</view>
      <view class="m-btn ghost" bindtap="onRefund">申请退款</view>
    </view>
  </view>

  <!-- 菜单列表（三组：账户与认证 / 资产与交易 / 帮助与更多） -->
  <block wx:for="{{menuGroups}}" wx:for-item="group" wx:key="title">
    <view class="grp-lab">{{group.title}}</view>
    <view class="card menu">
      <view
        class="m-row"
        wx:for="{{group.items}}"
        wx:for-item="item"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="onMenuTap"
      >
        <text class="m-row-t">{{item.title}}</text>
        <view class="m-right">
          <!-- 级别与佣金：等级徽 + 累计笔数 -->
          <block wx:if="{{item.level}}">
            <lv-badge level="{{item.level}}"></lv-badge>
            <text class="m-trades">{{item.trades}} 笔</text>
          </block>
          <!-- 违约红点（>0 才显示） -->
          <text wx:elif="{{item.badge > 0}}" class="m-badge">{{item.badge}}</text>
          <!-- 实名脱敏名等 chip -->
          <text wx:elif="{{item.chip}}" class="m-chip {{item.chip === '未实名' ? 'off' : ''}}">{{item.chip}}</text>
          <!-- 普通右值（¥余额 / 地址数 / 版本号） -->
          <text wx:elif="{{item.value}}" class="m-val">{{item.value}}</text>
          <text class="m-arrow">›</text>
        </view>
      </view>
    </view>
  </block>

</view>
