.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 0 24rpx 40rpx;
}

/* 顶部 tab */
.tabs {
  display: flex;
  position: sticky;
  top: 0;
  z-index: 5;
  gap: 12rpx;
  padding: 20rpx 0 16rpx;
  background: var(--paper);
}
.tab {
  position: relative;
  flex: 1;
  padding: 18rpx 8rpx;
  border-radius: var(--radius-sm);
  text-align: center;
  font-size: 28rpx;
  color: var(--ink-2);
  background: var(--card);
  box-shadow: var(--shadow);
}
.tab.on {
  color: #fff;
  font-weight: 700;
  background: linear-gradient(135deg, var(--btn-1), var(--btn-2));
}
.tab-badge {
  position: absolute;
  top: 2rpx;
  right: 8rpx;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
  border-radius: 14rpx;
  font-size: 18rpx;
  line-height: 28rpx;
  color: #fff;
  background: var(--up);
}

/* 筛选行：买卖向胶囊 + 单号搜索 */
.filter {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 4rpx;
  margin-bottom: 4rpx;
}
.filter-note {
  flex: 1;
  font-size: 22rpx;
  color: var(--muted);
}
.pills {
  display: flex;
  gap: 10rpx;
  flex: 1;
  min-width: 0;
}
.pill {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: var(--ink-2);
  background: var(--card);
  box-shadow: var(--shadow);
}
.pill.on {
  color: #fff;
  font-weight: 700;
  background: linear-gradient(135deg, var(--btn-1), var(--btn-2));
}
.search {
  flex-shrink: 0;
}
.search-input {
  width: 200rpx;
  height: 56rpx;
  box-sizing: border-box;
  padding: 0 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: var(--ink);
  background: var(--card);
  box-shadow: var(--shadow);
}
.search-ph { color: var(--faint); }

/* 列表 */
.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 8rpx;
}

/* 卡片 */
.card {
  padding: 24rpx;
  border-radius: var(--radius);
  background: var(--card);
  box-shadow: var(--shadow);
}

/* 顶行 */
.card-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.side {
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
}
.side-buy {
  color: var(--blue);
  background: var(--tag-blue-bg);
}
.side-sell {
  color: var(--gold-3);
  background: var(--cream);
}
.order-no {
  margin-left: auto;
  font-size: 20rpx;
  color: var(--muted);
  font-family: 'SF Mono', 'Menlo', monospace;
  letter-spacing: 0.5rpx;
}

/* 商品 */
.goods {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
  margin-top: 20rpx;
}
.goods-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--ink);
}
.goods-weight {
  font-size: 26rpx;
  color: var(--ink-2);
}

/* 价格 */
.prices {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid var(--line);
}
.price-line {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-top: 8rpx;
}
.price-line:first-child {
  margin-top: 0;
}
.price-label {
  font-size: 24rpx;
  color: var(--muted);
}
.price-cash {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--up);
}
.price-transfer {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--blue);
}

/* 倒计时 */
.countdown {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 16rpx;
  padding: 10rpx 16rpx;
  border-radius: var(--radius-sm);
  background: var(--cream);
}
.cd-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--up);
}
.cd-text {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--up);
}
/* A2 超时态：更醒目的红底 */
.countdown.over {
  background: var(--tag-orange-bg);
}
.countdown.over .cd-dot { background: var(--tag-orange); }
.countdown.over .cd-text { color: var(--tag-orange); }

/* 底部状态条 */
.status-bar {
  margin-top: 16rpx;
  padding: 12rpx 18rpx;
  border-radius: var(--radius-sm);
  font-size: 24rpx;
  font-weight: 700;
}
.status-bar.sell {
  color: var(--gold-3);
  background: var(--cream);
}
.status-bar.done {
  color: var(--down);
  background: #E6F4ED;
}

/* 底行 */
.card-foot {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}
.cp-actions {
  display: flex;
  gap: 10rpx;
  margin-left: auto;
}
.cp-btn {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
}
.cp-btn.call { background: linear-gradient(135deg, #F08A6F, #E0492F); }
.cp-btn.wechat { background: linear-gradient(135deg, #46B98A, #1FA766); }
.cp-btn.addr { background: linear-gradient(135deg, #5A87E0, #3E63C7); }

/* 操作按钮行 */
.ops {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid var(--line);
}
.op-btn {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 700;
}
.op-btn.ghost {
  color: var(--ink-2);
  background: var(--card);
  border: 2rpx solid var(--line);
}
.op-btn.danger {
  color: var(--up);
  background: var(--card);
  border: 2rpx solid var(--up);
}
.op-btn.primary {
  color: #fff;
  background: linear-gradient(135deg, var(--btn-1), var(--btn-2));
}
.counterparty {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.cp-name {
  font-size: 24rpx;
  color: var(--ink-2);
}
.complete-time {
  margin-left: auto;
  font-size: 22rpx;
  color: var(--down);
}

/* 空态 / 页脚 */
.empty {
  padding: 120rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: var(--muted);
}
.foot {
  padding: 32rpx 0 8rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--faint);
}
