.page { height: 100vh; box-sizing: border-box; padding: 0 24rpx 40rpx; }

/* 顶部标题 */
.mh { padding: 24rpx 4rpx 8rpx; }
.mh-title { font-size: 34rpx; font-weight: 800; color: var(--ink); }
.mh-sub { font-size: 22rpx; color: var(--muted); margin-top: 6rpx; }

/* 金属切换 tab：黄金 / 白银 / 铂金，选中态金色高亮 */
.mtabs {
  display: flex; gap: 14rpx; margin: 18rpx 0 22rpx;
  padding: 8rpx; border-radius: 999rpx;
  background: #fff; box-shadow: var(--shadow);
}
.mtab {
  flex: 1; text-align: center;
  padding: 16rpx 0; border-radius: 999rpx;
  font-size: 26rpx; font-weight: 700; color: var(--ink-2);
  transition: color .15s, background .15s;
}
.mtab.on {
  color: #fff;
  background: linear-gradient(135deg, var(--gold-1), var(--gold-3));
  box-shadow: 0 6rpx 16rpx rgba(184, 145, 63, .32);
}

/* 列表头：与 goods-row 列宽对齐（名称=flex1 / 库存=110 / 价格=180 / 操作=76） */
.list-head { display: flex; align-items: center; padding: 24rpx 8rpx 10rpx; font-size: 20rpx; color: var(--muted); }
.lh-name { flex: 1; }
.lh-stock { flex: 0 0 110rpx; text-align: center; }
.lh-price { flex: 0 0 180rpx; text-align: center; }
.lh-act { flex: 0 0 76rpx; text-align: center; }

.empty { text-align: center; color: var(--muted); font-size: 24rpx; padding: 60rpx 0; }
.foot { text-align: center; color: var(--muted); font-size: 22rpx; padding: 24rpx 0 40rpx; }
