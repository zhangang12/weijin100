<view class="page">
  <view class="mh">
    <view class="mh-title">实时行情</view>
    <view class="mh-sub">红涨绿跌 · 仅供参考</view>
  </view>

  <view class="mtabs">
    <view
      wx:for="{{metalTabs}}"
      wx:key="key"
      data-metal="{{item.key}}"
      bindtap="onMetal"
      class="mtab {{metal === item.key ? 'on' : ''}}"
    >{{item.label}}</view>
  </view>

  <price-card quote="{{quote}}" />

  <!-- 排序栏 + 结果计数 -->
  <view class="sortbar">
    <view
      wx:for="{{sortOptions}}"
      wx:key="key"
      data-key="{{item.key}}"
      bindtap="onSort"
      class="sort {{sortKey === item.key ? 'on' : ''}}"
    >
      <text>{{item.label}}</text>
      <text wx:if="{{sortKey === item.key}}" class="arrow">{{sortDir === 'desc' ? '↓' : '↑'}}</text>
    </view>
    <view class="sp"></view>
    <view class="sort-cnt">共 <text class="n">{{total}}</text> 条</view>
  </view>

  <view class="list-head">
    <text class="lh-name">名称 / 类别</text>
    <text class="lh-stock">库存/起批</text>
    <text class="lh-price">价格(元/克)</text>
    <text class="lh-act">操作</text>
  </view>

  <view class="list">
    <goods-row
      wx:for="{{listings}}"
      wx:key="listingId"
      item="{{item}}"
      bind:lock="onLock"
    />
    <view wx:if="{{!loading && !loadingMore && listings.length === 0}}" class="empty">
      该筛选暂无挂单，换个条件试试
    </view>
  </view>

  <view class="foot">
    <block wx:if="{{loading}}">加载中…</block>
    <block wx:elif="{{loadingMore}}">正在加载更多…</block>
    <block wx:elif="{{listings.length > 0 && !hasMore}}">—— 已经到底啦 ——</block>
    <block wx:elif="{{hasMore}}">上拉加载更多</block>
  </view>
</view>
