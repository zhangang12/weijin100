.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
}

/* 资质补全提示条 */
.alert {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-radius: var(--radius-sm);
  background: var(--tag-orange-bg);
  border: 2rpx solid #F6D9BF;
}
.alert-ic {
  flex: none;
  width: 32rpx;
  height: 32rpx;
  margin-right: 14rpx;
  border-radius: 50%;
  background: var(--tag-orange);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 32rpx;
  text-align: center;
}
.alert-tx {
  font-size: 26rpx;
  color: var(--tag-orange);
  font-weight: 600;
}

/* 卡片 */
.card {
  margin-top: 24rpx;
  padding: 28rpx;
  background: var(--card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
}
.sec-tt {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 22rpx;
}

/* segment 分段选择 */
.seg {
  display: flex;
  padding: 6rpx;
  border-radius: var(--radius-sm);
  background: var(--paper);
}
.seg-i {
  flex: 1;
  height: 72rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: var(--ink-2);
  line-height: 72rpx;
  text-align: center;
}
.seg-i.on {
  background: var(--card);
  color: var(--gold-3);
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(70, 52, 20, .08);
}

/* chips 单选 */
.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.chip {
  padding: 16rpx 36rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  color: var(--ink-2);
  background: var(--paper);
  border: 2rpx solid transparent;
}
.chip.on {
  color: var(--gold-3);
  background: var(--cream);
  border-color: var(--gold-2);
  font-weight: 700;
}

/* 输入字段 */
.field {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-sm);
  background: var(--paper);
}
.field.mt {
  margin-top: 20rpx;
}
.field-k {
  flex: none;
  font-size: 28rpx;
  color: var(--ink-2);
  margin-right: 20rpx;
}
.ipt {
  flex: 1;
  height: 88rpx;
  font-size: 30rpx;
  color: var(--ink);
}
.ipt.sm {
  flex: none;
  width: 180rpx;
}
.unit {
  flex: none;
  margin-left: 12rpx;
  font-size: 26rpx;
  color: var(--muted);
}
.field-tip {
  margin-top: 14rpx;
  padding-left: 8rpx;
  font-size: 24rpx;
  color: var(--muted);
}

/* 不支持转账开关行 */
.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  padding: 4rpx 8rpx;
}

/* 价格输入行 */
.price-row {
  display: flex;
  align-items: center;
  height: 88rpx;
  margin-top: 20rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-sm);
  background: var(--paper);
}
.price-row.disabled {
  opacity: .45;
}
.sign {
  flex: none;
  width: 64rpx;
  height: 64rpx;
  margin-right: 16rpx;
  border-radius: 14rpx;
  background: var(--cream);
  color: var(--gold-3);
  font-size: 40rpx;
  font-weight: 700;
  line-height: 64rpx;
  text-align: center;
}

/* 同意勾选 */
.agree {
  display: flex;
  align-items: center;
  margin-top: 28rpx;
  padding: 8rpx;
}
.cbox {
  flex: none;
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
  border: 3rpx solid var(--faint);
  border-radius: 10rpx;
  background: var(--card);
  box-sizing: border-box;
}
.cbox.on {
  border-color: var(--btn-2);
  background: var(--btn-2);
}
.cbox-tick {
  display: block;
  width: 100%;
  height: 100%;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 34rpx;
  text-align: center;
}
.agree-tx {
  font-size: 28rpx;
  color: var(--ink);
}

/* 底部按钮 */
.footer {
  margin-top: 44rpx;
  padding: 0 8rpx;
}
.btn {
  width: 100%;
  height: 92rpx;
  border-radius: var(--radius);
  background: linear-gradient(135deg, var(--btn-1), var(--btn-2));
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 92rpx;
  text-align: center;
  box-shadow: 0 8rpx 20rpx rgba(192, 154, 76, .28);
}
.btn::after {
  border: none;
}
.btn-off {
  background: var(--line);
  color: var(--muted);
  box-shadow: none;
}

/* 旧料折后实重黄色提示（F2） */
.warn {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  border-radius: var(--radius-sm);
  background: var(--tag-orange-bg);
  border: 2rpx solid #F6D9BF;
  font-size: 24rpx;
  color: var(--tag-orange);
  font-weight: 600;
}
.warn-ic {
  flex: none;
  width: 30rpx;
  height: 30rpx;
  margin-right: 12rpx;
  border-radius: 50%;
  background: var(--tag-orange);
  color: #fff;
  font-size: 22rpx;
  line-height: 30rpx;
  text-align: center;
}

/* ============ 确认发布清单弹窗（页内 modal） ============ */
.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 200;
  background: rgba(30, 22, 10, .45);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  visibility: hidden;
  opacity: 0;
  transition: opacity .2s;
}
.modal-mask.on {
  visibility: visible;
  opacity: 1;
}
.modal-sheet {
  width: 100%;
  box-sizing: border-box;
  background: var(--card);
  border-radius: 36rpx 36rpx 0 0;
  padding: 28rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  max-height: 88vh;
  overflow-y: auto;
  transform: translateY(100%);
  transition: transform .25s;
}
.modal-sheet.up {
  transform: translateY(0);
}
.modal-head {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.modal-t {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--ink);
}
.modal-x {
  margin-left: auto;
  color: var(--muted);
  font-size: 32rpx;
  padding: 0 8rpx;
}

/* 清单明细行 */
.dl-list {
  padding: 8rpx 20rpx;
  border-radius: var(--radius-sm);
  background: var(--paper);
}
.dl {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 2rpx solid var(--line);
}
.dl:last-child {
  border-bottom: none;
}
.dk {
  flex: none;
  font-size: 26rpx;
  color: var(--ink-2);
  margin-right: 24rpx;
}
.dv {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: var(--ink);
  font-weight: 600;
}

/* 发布提醒 3 条 */
.modal-rules {
  margin-top: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.mr {
  font-size: 24rpx;
  color: var(--ink-2);
  line-height: 1.6;
}
.hot {
  color: var(--up, #E0492F);
  font-weight: 700;
}

/* 弹窗按钮组 */
.modal-ops {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}
.btn2 {
  flex: 1;
  height: 88rpx;
  border-radius: var(--radius);
  background: linear-gradient(135deg, var(--btn-1), var(--btn-2));
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 88rpx;
  text-align: center;
  box-shadow: 0 8rpx 20rpx rgba(192, 154, 76, .28);
}
.btn2.line {
  background: var(--card);
  color: var(--gold-3);
  border: 2rpx solid var(--gold-2);
  box-shadow: none;
}
.btn2.btn-off {
  background: var(--line);
  color: var(--muted);
  box-shadow: none;
}
