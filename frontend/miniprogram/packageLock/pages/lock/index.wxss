.page { height: 100vh; box-sizing: border-box; padding: 20rpx 24rpx 40rpx; }

.seller { display: flex; align-items: center; gap: 16rpx; background: #fff; border-radius: var(--radius); padding: 20rpx; box-shadow: var(--shadow); }
.seller .avatar { width: 64rpx; height: 64rpx; border-radius: 50%; background: linear-gradient(135deg, #E3C588, #B8913F); color: #fff; font-weight: 800; font-size: 30rpx; display: flex; align-items: center; justify-content: center; }
.sinfo { flex: 1; min-width: 0; }
.sinfo .l1 { display: flex; align-items: center; gap: 10rpx; }
.sinfo .uid { font-size: 28rpx; font-weight: 700; color: var(--ink); }
.sinfo .l2 { font-size: 22rpx; color: var(--muted); margin-top: 6rpx; }

.card { background: #fff; border-radius: var(--radius); padding: 24rpx; box-shadow: var(--shadow); margin-top: 20rpx; }

.price .prow { display: flex; align-items: baseline; gap: 14rpx; padding: 10rpx 0; }
.price .chip { font-size: 22rpx; font-weight: 800; padding: 4rpx 14rpx; border-radius: 8rpx; color: #fff; }
.price .chip.cash { background: linear-gradient(135deg, #F08A6F, #E0492F); }
.price .chip.trans { background: linear-gradient(135deg, #5A87E0, #3E63C7); }
.price .pv { font-size: 38rpx; font-weight: 800; color: var(--ink); }
.price .u { font-size: 22rpx; color: var(--muted); }

.qtitle { display: flex; align-items: center; gap: 12rpx; font-size: 28rpx; font-weight: 700; color: var(--ink); margin-bottom: 18rpx; }
.qbody { display: flex; align-items: center; flex-wrap: wrap; gap: 14rpx; }
.qbig { font-size: 48rpx; font-weight: 800; color: var(--ink); }
.qu { font-size: 24rpx; color: var(--muted); }
.qtip { width: 100%; font-size: 22rpx; color: var(--muted); margin-top: 8rpx; }
.qinput { flex: 1; min-width: 200rpx; height: 80rpx; border-bottom: 2rpx solid var(--gold-2); font-size: 40rpx; font-weight: 800; color: var(--ink); }
.maxbtn { padding: 10rpx 22rpx; border-radius: 12rpx; background: linear-gradient(180deg, var(--btn-1), var(--btn-2)); color: #fff; font-size: 22rpx; font-weight: 700; }
.stepper { display: flex; align-items: center; gap: 20rpx; }
.sbtn { width: 64rpx; height: 64rpx; border-radius: 14rpx; border: 2rpx solid var(--gold-2); color: var(--gold-3); font-size: 40rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; }
.snum { font-size: 40rpx; font-weight: 800; color: var(--ink); min-width: 60rpx; text-align: center; }

.totals .trow { display: flex; justify-content: space-between; align-items: center; padding: 12rpx 0; border-top: 1rpx dashed var(--line-2); }
.totals .trow:first-child { border-top: none; }
.totals .tk { font-size: 26rpx; color: var(--ink-2); }
.totals .tv { font-size: 34rpx; font-weight: 800; }
.totals .tv.cash { color: var(--up); }
.totals .tv.trans { color: var(--blue); }
.totals .tv.off { font-size: 24rpx; color: var(--up); font-weight: 700; }

.note { font-size: 22rpx; color: var(--muted); text-align: center; padding: 24rpx 20rpx 120rpx; line-height: 1.6; }

.cta { position: fixed; left: 0; right: 0; bottom: 0; padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom)); background: linear-gradient(180deg, rgba(242,239,234,0), var(--paper) 40%); }
.btn { height: 92rpx; border-radius: 20rpx; background: linear-gradient(180deg, var(--btn-1), var(--btn-2)); color: #fff; font-size: 32rpx; font-weight: 800; display: flex; align-items: center; justify-content: center; box-shadow: 0 12rpx 28rpx rgba(184,145,63,.32); }
.btn.disabled { opacity: .6; }
.tnum { font-variant-numeric: tabular-nums; }
