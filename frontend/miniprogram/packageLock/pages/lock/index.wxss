.page { height: 100vh; box-sizing: border-box; padding: 20rpx 24rpx 40rpx; }

.seller { display: flex; align-items: center; gap: 16rpx; background: #fff; border-radius: var(--radius); padding: 20rpx; box-shadow: var(--shadow); }
.seller .avatar { width: 64rpx; height: 64rpx; border-radius: 50%; background: linear-gradient(135deg, #E3C588, #B8913F); color: #fff; font-weight: 800; font-size: 30rpx; display: flex; align-items: center; justify-content: center; }
.sinfo { flex: 1; min-width: 0; }
.sinfo .l1 { display: flex; align-items: center; gap: 10rpx; }
.sinfo .uid { font-size: 28rpx; font-weight: 700; color: var(--ink); }
.sinfo .l2 { font-size: 22rpx; color: var(--muted); margin-top: 6rpx; }

.card { background: #fff; border-radius: var(--radius); padding: 24rpx; box-shadow: var(--shadow); margin-top: 20rpx; }

/* 报价 */
.price .prow { display: flex; align-items: baseline; gap: 14rpx; padding: 10rpx 0; }
.price .chip { font-size: 22rpx; font-weight: 800; padding: 4rpx 14rpx; border-radius: 8rpx; color: #fff; }
.price .chip.cash { background: linear-gradient(135deg, #F08A6F, #E0492F); }
.price .chip.trans { background: linear-gradient(135deg, #5A87E0, #3E63C7); }
.price .chip.trans.off { background: var(--faint); }
.price .pv { font-size: 38rpx; font-weight: 800; color: var(--ink); }
.price .pv-off { font-size: 26rpx; font-weight: 700; color: var(--up); }
.price .u { font-size: 22rpx; color: var(--muted); }

/* 剩余库存进度条 */
.stock { margin-top: 12rpx; padding-top: 16rpx; border-top: 1rpx dashed var(--line-2); }
.stock-head { display: flex; justify-content: space-between; font-size: 22rpx; color: var(--muted); }
.stock-head .hl { color: var(--gold-3); font-weight: 800; }
.stock-bar { height: 10rpx; border-radius: 6rpx; background: var(--line); margin-top: 10rpx; overflow: hidden; }
.stock-fill { height: 100%; border-radius: 6rpx; background: linear-gradient(90deg, var(--gold-1), var(--gold-3)); }

/* 数量 */
.qtitle { display: flex; align-items: center; gap: 12rpx; font-size: 28rpx; font-weight: 700; color: var(--ink); margin-bottom: 18rpx; }
.qbody { display: flex; align-items: center; flex-wrap: wrap; gap: 14rpx; }
.qbody.locked { align-items: center; }
.lk-ic { font-size: 30rpx; }
.qbig { font-size: 48rpx; font-weight: 800; color: var(--ink); }
.qu { font-size: 24rpx; color: var(--muted); }
.qtip { width: 100%; font-size: 22rpx; color: var(--muted); margin-top: 8rpx; }
.qtip.err { color: var(--up); font-weight: 700; }
.qfield { flex: 1; min-width: 200rpx; height: 88rpx; padding: 0 20rpx; border-bottom: 2rpx solid var(--gold-2); display: flex; align-items: baseline; gap: 8rpx; }
.qfield.err { border-bottom-color: var(--up); }
.qv { font-size: 44rpx; font-weight: 800; color: var(--ink); }
.qv.ph { font-size: 28rpx; font-weight: 400; color: var(--faint); }
.maxbtn { padding: 12rpx 24rpx; border-radius: 12rpx; background: linear-gradient(180deg, var(--btn-1), var(--btn-2)); color: #fff; font-size: 22rpx; font-weight: 700; }
.stepper { display: flex; align-items: center; gap: 20rpx; }
.sbtn { width: 64rpx; height: 64rpx; border-radius: 14rpx; border: 2rpx solid var(--gold-2); color: var(--gold-3); font-size: 40rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; }
.sbtn.dis { opacity: .35; }
.snum { font-size: 40rpx; font-weight: 800; color: var(--ink); min-width: 60rpx; text-align: center; }

/* 订单合计 */
.totals { margin-top: 20rpx; padding-top: 8rpx; border-top: 1rpx dashed var(--line-2); }
.totals .trow { display: flex; justify-content: space-between; align-items: center; padding: 12rpx 0; }
.totals .tk { display: flex; align-items: center; gap: 10rpx; font-size: 26rpx; color: var(--ink-2); }
.totals .dot { width: 14rpx; height: 14rpx; border-radius: 50%; }
.totals .dot.cash { background: var(--up); }
.totals .dot.trans { background: var(--blue); }
.totals .dot.off { background: var(--faint); }
.totals .tv { font-size: 34rpx; font-weight: 800; }
.totals .tv.cash { color: var(--up); }
.totals .tv.trans { color: var(--blue); }
.totals .tv.off { font-size: 24rpx; color: var(--up); font-weight: 700; }
.formula { font-size: 21rpx; color: var(--muted); margin-top: 6rpx; }
.formula .cash { color: var(--up); font-weight: 700; }
.formula .trans { color: var(--blue); font-weight: 700; }

/* 付款方式 */
.paypick { display: flex; align-items: center; gap: 16rpx; margin-top: 20rpx; padding-top: 18rpx; border-top: 1rpx dashed var(--line-2); }
.pk-lbl { font-size: 26rpx; color: var(--ink-2); }
.pk-opts { display: flex; align-items: center; gap: 12rpx; }
.pk { padding: 10rpx 30rpx; border-radius: 14rpx; border: 2rpx solid var(--line); color: var(--ink-2); font-size: 26rpx; font-weight: 700; background: var(--paper); }
.pk.on { border-color: var(--gold-2); color: var(--gold-3); background: var(--cream); }
.pk-note { font-size: 22rpx; color: var(--up); font-weight: 700; }

/* 软约束卡 */
.level-hint { margin-top: 20rpx; background: #fff; border-radius: var(--radius); padding: 20rpx 24rpx; box-shadow: var(--shadow); border: 2rpx solid transparent; }
.level-hint.warn { border-color: #F3D0C8; background: #FFF7F5; }
.lh-tags { display: flex; gap: 12rpx; margin-bottom: 12rpx; }
.lh-tag { font-size: 22rpx; font-weight: 700; padding: 4rpx 16rpx; border-radius: 999rpx; }
.lh-tag.lv { color: #7C5CBF; background: #F0EAFB; }
.lh-tag.dep { color: var(--gold-3); background: var(--cream); }
.lh-info { font-size: 24rpx; color: var(--ink-2); }
.lh-info .b { color: var(--ink); font-weight: 800; }
.lh-info .over { color: var(--up); font-weight: 800; }
.lh-link { display: inline-block; margin-top: 12rpx; font-size: 23rpx; font-weight: 700; color: var(--gold-3); border-bottom: 2rpx dashed var(--gold-2); padding-bottom: 2rpx; }

.note { font-size: 22rpx; color: var(--muted); text-align: center; padding: 24rpx 20rpx 160rpx; line-height: 1.6; }

.cta { position: fixed; left: 0; right: 0; bottom: 0; padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom)); background: linear-gradient(180deg, rgba(242,239,234,0), var(--paper) 40%); }
.btn { height: 92rpx; border-radius: 20rpx; background: linear-gradient(180deg, var(--btn-1), var(--btn-2)); color: #fff; font-size: 32rpx; font-weight: 800; display: flex; align-items: center; justify-content: center; box-shadow: 0 12rpx 28rpx rgba(184,145,63,.32); }
.btn.disabled { opacity: .45; box-shadow: none; }
.btn.line { background: #fff; color: var(--ink-2); border: 2rpx solid var(--line); box-shadow: none; }

/* 数字键盘提示 */
.kb-tip { font-size: 22rpx; color: var(--muted); text-align: center; margin-bottom: 14rpx; }

/* ============ 确认锁价订单弹窗 ============ */
.cf { background: var(--cream); border-radius: var(--radius-sm); padding: 6rpx 20rpx; margin-bottom: 16rpx; }
.dl-list { }
.dl { display: flex; justify-content: space-between; align-items: baseline; gap: 20rpx; padding: 16rpx 0; border-top: 1rpx dashed rgba(184,145,63,.2); }
.dl:first-child { border-top: none; }
.dl .dk { font-size: 24rpx; color: var(--ink-2); flex-shrink: 0; }
.dl .dv { font-size: 26rpx; font-weight: 700; color: var(--ink); text-align: right; }
.dl .dv.big { font-size: 40rpx; font-weight: 800; color: var(--up); }

.warm-tip { display: flex; align-items: flex-start; gap: 10rpx; background: var(--tag-orange-bg); border-radius: var(--radius-sm); padding: 16rpx 20rpx; font-size: 23rpx; color: #9A5A22; line-height: 1.6; margin-bottom: 16rpx; }
.warm-tip .wt-ic { color: var(--tag-orange); font-weight: 800; }
.warm-tip .b { color: var(--up); font-weight: 800; }

.rules { margin-bottom: 16rpx; }
.rule { display: flex; gap: 12rpx; padding: 8rpx 0; }
.rule .rn { flex-shrink: 0; width: 32rpx; height: 32rpx; border-radius: 50%; background: var(--tag-orange); color: #fff; font-size: 20rpx; font-weight: 800; display: flex; align-items: center; justify-content: center; }
.rule .rt { font-size: 22rpx; color: var(--ink-2); line-height: 1.6; }
.rule .rt .k { color: var(--up); font-weight: 700; }

.agree { display: flex; align-items: center; gap: 14rpx; padding: 18rpx 4rpx; font-size: 25rpx; color: var(--ink-2); }
.agree .b { color: var(--ink); font-weight: 700; }
.agree .check { width: 36rpx; height: 36rpx; border-radius: 8rpx; border: 2rpx solid var(--gold-2); color: #fff; font-size: 24rpx; font-weight: 900; display: flex; align-items: center; justify-content: center; background: #fff; }
.agree.on .check { background: linear-gradient(135deg, var(--btn-1), var(--btn-2)); border-color: var(--btn-2); }

.cf-btns { display: flex; gap: 16rpx; }
.cf-btns .btn { flex: 1; }

.tnum { font-variant-numeric: tabular-nums; }
