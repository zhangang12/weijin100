<!-- 处理中：全屏居中 + 金色旋转环（并发抢锁仲裁缓冲） -->
<view class="loading" wx:if="{{status === 'processing'}}">
  <view class="ring"></view>
  <view class="ld-title">正在锁价校验…</view>
  <view class="ld-desc">正在为你锁定价格，请稍候</view>
</view>

<!-- 成功态 -->
<scroll-view scroll-y class="page" wx:elif="{{status === 'success'}}">
  <result status="ok" title="锁价成功" desc="商家正在备货，将及时送单">
    <view slot="" class="ops-inner">
      <view class="btn ghost" bindtap="goMarket">继续选购</view>
      <view class="btn" bindtap="goOrder">查看订单</view>
    </view>
  </result>

  <!-- 商家联系卡 -->
  <view class="card contact">
    <view class="cc-head">
      <view class="sm-avatar">{{avatar || '商'}}</view>
      <view class="cc-name">
        <view class="row1"><text class="tnum">{{seller}}</text><lv-badge wx:if="{{level}}" level="{{level}}"></lv-badge><text class="deals" wx:if="{{deals}}">· {{deals}} 单</text></view>
        <view class="cc-goods">{{goods}}<text wx:if="{{weight}}"> · {{weight}}g</text></view>
        <view class="cc-price">
          <text class="cash">现金 ¥{{cashTotal}}</text>
          <block wx:if="{{support}}"> / <text class="trans">转账 ¥{{transferTotal}}</text></block>
          <block wx:else> / <text class="strike">转账</text> <text class="no-trans">不支持转账</text></block>
        </view>
      </view>
      <view class="cc-status"><text class="pulse"></text>备货中</view>
    </view>

    <view class="contact-rows">
      <view class="contact-row" wx:if="{{hasPhone}}" bindtap="onCallSeller">
        <view class="contact-ic phone-bg">☎</view>
        <view class="contact-text"><text class="contact-lbl">拨打电话</text><text class="contact-val tnum">{{phone}}</text></view>
        <text class="contact-act call">拨打</text>
      </view>
      <view class="contact-row" wx:if="{{hasWechat}}" bindtap="onCopyWechat">
        <view class="contact-ic wechat-bg">微</view>
        <view class="contact-text"><text class="contact-lbl">复制微信</text><text class="contact-val tnum">{{wechat}}</text></view>
        <text class="contact-act copy">复制</text>
      </view>
      <view class="no-contact" wx:if="{{!hasPhone && !hasWechat}}">交割联系方式将在「我的订单」详情中展示</view>
    </view>
  </view>

  <!-- 订单号 -->
  <view class="card info" wx:if="{{orderNo}}">
    <view class="irow"><text class="ik">订单号</text><text class="iv tnum">{{orderNo}}</text></view>
    <view class="tip">请在 <text class="hl">4 小时</text>内与商家完成线下实名交割</view>
  </view>

  <!-- 成功温馨提示（橙色卡） -->
  <view class="warm-tip">
    <view class="wt-row"><text class="wt-ic">ⓘ</text><text>本次锁价已成功！线下实物交割完成后，请双方前往<text class="b">【我的订单】</text>点确认收货、完成交易，系统核验无误后<text class="b">解冻保证金、解除限制</text>。</text></view>
    <view class="wt-warn">⚠️ 重要提醒</view>
    <view class="wt-li">1. 交割完毕逾期未确认，平台将<text class="b">持续冻结保证金与操作权限</text>；</view>
    <view class="wt-li">2. 交割后如有异议须<text class="b">72 小时内</text>提交申诉；超时系统<text class="b">自动判定完结</text>，平台不再介入。</view>
  </view>
</scroll-view>

<!-- 失败态 -->
<view class="page" wx:else>
  <result status="err" title="锁价失败" desc="{{failReason || '订单已被抢走'}}">
    <view slot="" class="ops-inner">
      <view class="btn ghost" bindtap="contactService">联系客服</view>
      <view class="btn" bindtap="goMarket">浏览同类</view>
    </view>
  </result>

  <!-- 失败详情卡 -->
  <view class="card err-card">
    <view class="dl"><text class="dk err">失败原因</text><text class="dv err">{{failReason || '订单已被抢走'}}</text></view>
    <view class="dl" wx:if="{{goods}}"><text class="dk">商品</text><text class="dv">{{goods}}</text></view>
    <view class="dl" wx:if="{{seller}}"><text class="dk">商家</text><text class="dv">{{seller}}<text wx:if="{{level}}"> · {{level}}</text></text></view>
    <view class="dl" wx:if="{{weight}}"><text class="dk">期望数量</text><text class="dv tnum">{{weight}} g</text></view>
  </view>
</view>
