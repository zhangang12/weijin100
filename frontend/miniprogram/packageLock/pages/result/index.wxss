.page { min-height: 100vh; box-sizing: border-box; padding: 24rpx 24rpx calc(40rpx + env(safe-area-inset-bottom)); }

/* ============ 处理中：全屏居中 ============ */
.loading {
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx calc(120rpx + env(safe-area-inset-bottom));
}
.ring {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  border: 8rpx solid var(--line);
  border-top-color: var(--gold-3);
  animation: spin 0.9s linear infinite;
}
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
.ld-title { font-size: 32rpx; font-weight: 800; color: var(--ink); margin-top: 36rpx; }
.ld-desc { font-size: 24rpx; color: var(--ink-2); margin-top: 12rpx; }

/* ============ 卡片 ============ */
.card { background: var(--card); border-radius: var(--radius); padding: 24rpx; box-shadow: var(--shadow); margin-top: 20rpx; }

/* 订单号 + 提示 */
.info .irow { display: flex; justify-content: space-between; align-items: center; padding-bottom: 16rpx; border-bottom: 1rpx dashed var(--line-2); }
.info .ik { font-size: 26rpx; color: var(--ink-2); }
.info .iv { font-size: 28rpx; font-weight: 800; color: var(--ink); }
.info .tip { font-size: 24rpx; color: var(--ink-2); line-height: 1.6; padding-top: 16rpx; }
.info .tip .hl { color: var(--up); font-weight: 800; }

/* ============ 商家联系卡（成功态） ============ */
.contact .cc-head { display: flex; align-items: flex-start; gap: 16rpx; padding-bottom: 18rpx; border-bottom: 1rpx dashed var(--line-2); }
.contact .sm-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; background: linear-gradient(135deg, #E3C588, #B8913F); color: #fff; font-weight: 800; font-size: 32rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.contact .cc-name { flex: 1; min-width: 0; }
.contact .cc-name .row1 { display: flex; align-items: center; gap: 10rpx; font-size: 28rpx; font-weight: 800; color: var(--ink); }
.contact .cc-name .deals { font-size: 22rpx; font-weight: 700; color: var(--gold-3); }
.contact .cc-goods { font-size: 22rpx; color: var(--muted); margin-top: 6rpx; }
.contact .cc-price { font-size: 24rpx; margin-top: 6rpx; }
.contact .cc-price .cash { color: var(--up); font-weight: 800; }
.contact .cc-price .trans { color: var(--blue); font-weight: 800; }
.contact .cc-price .strike { color: var(--faint); text-decoration: line-through; }
.contact .cc-price .no-trans { font-size: 20rpx; color: var(--up); font-weight: 700; background: #FFEBE7; border: 1rpx solid #F5D3CC; padding: 2rpx 10rpx; border-radius: 6rpx; }
.contact .cc-status { flex-shrink: 0; display: flex; align-items: center; gap: 8rpx; font-size: 22rpx; font-weight: 700; color: var(--down); }
.contact .cc-status .pulse { width: 12rpx; height: 12rpx; border-radius: 50%; background: var(--down); }

.contact-rows { margin-top: 8rpx; }
.contact-row { display: flex; align-items: center; gap: 16rpx; padding: 18rpx 0; border-top: 1rpx dashed var(--line-2); }
.contact-row:first-child { border-top: none; }
.contact-ic { width: 56rpx; height: 56rpx; border-radius: 14rpx; color: #fff; font-size: 28rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.contact-ic.phone-bg { background: linear-gradient(135deg, #F08A6F, #E0492F); }
.contact-ic.wechat-bg { background: linear-gradient(135deg, #4CC168, #249746); }
.contact-text { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4rpx; }
.contact-lbl { font-size: 22rpx; color: var(--muted); }
.contact-val { font-size: 28rpx; font-weight: 800; color: var(--ink); }
.contact-act { padding: 12rpx 26rpx; border-radius: 14rpx; font-size: 24rpx; font-weight: 700; color: #fff; }
.contact-act.call { background: linear-gradient(135deg, #F08A6F, #E0492F); }
.contact-act.copy { background: linear-gradient(135deg, #5A87E0, #3E63C7); }
.no-contact { font-size: 22rpx; color: var(--muted); padding: 10rpx 0; }

/* ============ 温馨提示（橙色卡） ============ */
.warm-tip { margin-top: 20rpx; background: var(--tag-orange-bg); border-radius: var(--radius); padding: 22rpx 24rpx; }
.warm-tip .wt-row { display: flex; align-items: flex-start; gap: 10rpx; font-size: 23rpx; color: #9A5A22; line-height: 1.6; }
.warm-tip .wt-ic { color: var(--tag-orange); font-weight: 800; }
.warm-tip .wt-warn { margin-top: 12rpx; padding-top: 12rpx; border-top: 1rpx dashed #F3DBA5; color: var(--up); font-weight: 800; font-size: 23rpx; }
.warm-tip .wt-li { font-size: 22rpx; color: #9A5A22; line-height: 1.6; margin-top: 6rpx; }
.warm-tip .b { color: var(--up); font-weight: 800; }

/* ============ 失败详情卡 ============ */
.err-card .dl { display: flex; justify-content: space-between; align-items: baseline; gap: 20rpx; padding: 16rpx 0; border-top: 1rpx dashed var(--line-2); }
.err-card .dl:first-child { border-top: none; }
.err-card .dk { font-size: 24rpx; color: var(--ink-2); flex-shrink: 0; }
.err-card .dk.err { color: var(--up); font-weight: 700; }
.err-card .dv { font-size: 26rpx; font-weight: 700; color: var(--ink); text-align: right; }
.err-card .dv.err { color: var(--up); }

/* ============ result 组件 slot 内的操作按钮 ============ */
.ops-inner { display: flex; gap: 16rpx; width: 100%; }
.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 800;
  background: linear-gradient(180deg, var(--btn-1), var(--btn-2));
  color: #fff;
  box-shadow: 0 12rpx 28rpx rgba(184, 145, 63, .30);
}
.btn.ghost {
  background: var(--card);
  color: var(--ink-2);
  border: 2rpx solid var(--line);
  box-shadow: none;
}

.tnum { font-variant-numeric: tabular-nums; }
